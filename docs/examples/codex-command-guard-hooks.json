{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cdxcore guard-hook pre-tool-use",
            "timeout": 3,
            "statusMessage": "CDXCore command guard"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cdxcore guard-hook post-tool-use",
            "timeout": 3,
            "statusMessage": "CDXCore command guard"
          }
        ]
      }
    ]
  }
}
